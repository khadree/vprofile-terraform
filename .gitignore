
# State files (managed in S3)
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
# *.tfvars
# *.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated files
.terraformrc
terraform.rc


# Local terraform directory (contains binaries and plugins)
.terraform/

# .lock files are usually okay to commit, but binaries are not
.terraform.lock.hcl
